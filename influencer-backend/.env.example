# Backend Environment Variables
# Copy these to your hosting platform's environment settings (e.g. Render, Railway)

# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:mysql://your-db-host:3306/influencer_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# ── URLs ──────────────────────────────────────────────────────────────────────
APP_FRONTEND_URL=https://makeadv.vercel.app
ALLOWED_ORIGINS=https://makeadv.vercel.app

# ── Spring ────────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
